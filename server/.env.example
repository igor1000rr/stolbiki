# Highrise Heist — серверные переменные окружения
# Скопируйте в .env и настройте

# Порт API сервера (по умолчанию 3001)
PORT=3001

# Путь к SQLite базе данных
DB_PATH=./data/stolbiki.db

# JWT секрет для авторизации (ОБЯЗАТЕЛЬНО сменить в продакшне!)
JWT_SECRET=your-secret-key-change-me

# Имена админов через запятую
ADMIN_USERNAMES=admin

# CORS: разрешённые origins через запятую
ALLOWED_ORIGINS=https://highriseheist.com,https://www.highriseheist.com,https://snatch-highrise.com,https://www.snatch-highrise.com,http://localhost:5173

# Node.js окружение (development | production)
NODE_ENV=production

# Web Push (VAPID) — для уведомлений «Ваш ход!» при offline оппоненте
# Генерация: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@highriseheist.com
