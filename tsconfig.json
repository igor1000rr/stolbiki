{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"]
  },
  "include": [
    "src/**/*",
    "server/**/*",
    "scripts/**/*",
    "vite.config.js",
    "vitest.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "android",
    "ios",
    "e2e",
    "server/node_modules",
    "server/data",
    "server/backups",
    "server/logs",
    "server/blog-posts",
    "gpu_train",
    "analysis",
    "public",
    "resources"
  ]
}
