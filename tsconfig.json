{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "server/game-engine.js",
    "server/anticheat.js",
    "server/helpers.js",
    "server/validate.js",
    "src/engine/game.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "server/node_modules",
    "android",
    "ios",
    "e2e",
    "tests"
  ]
}
